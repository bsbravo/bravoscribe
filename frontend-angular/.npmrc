# NgRx has not yet published a version whose peerDependencies range includes
# Angular 22 (latest @ngrx/store is 21.1.1, peer ^21.0.0) even though it works fine
# against Angular 22 in practice. legacy-peer-deps avoids an ERESOLVE failure on
# `npm install` until NgRx cuts a release with a wider peer range.
legacy-peer-deps=true
