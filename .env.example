# .env.example — copy to .env for local development
# These are local dev credentials only — never use in production
# Production secrets are managed via Azure Key Vault

# PostgreSQL (local only)
POSTGRES_PASSWORD=postgres
USER_SVC_DB_PASSWORD=user_svc_password
JOURNAL_SVC_DB_PASSWORD=journal_svc_password

# JWT keys — generate your own RS256 key pair for local dev
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# SendGrid (use a test key for local dev — emails won't send without it)
SENDGRID_API_KEY=

# Frontend URL (for password reset emails)
FRONTEND_URL=http://localhost:5173

# MongoDB (local dev)
MONGODB_URI=mongodb://mongo:mongo@localhost:27017/bravoscribe?authSource=admin
